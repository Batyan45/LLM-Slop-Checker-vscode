{
    "name": "llm-slop-checker",
    "displayName": "LLM Slop Checker",
    "description": "Highlights AI-generated slop in your code.",
    "version": "0.0.3",
    "icon": "images/icon.png",
    "publisher": "batyan-soft",
    "repository": {
        "type": "git",
        "url": "https://github.com/Batyan45/LLM-Slop-Checker-vscode"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "LLM Slop Checker",
            "properties": {
                "llmSlopChecker.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/Disable the LLM Slop Checker."
                },
                "llmSlopChecker.checkEmojis": {
                    "type": "boolean",
                    "default": true,
                    "description": "Highlight emojis in the code."
                },
                "llmSlopChecker.symbolReplacements": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "description": "Symbol and replacement in format 'symbol:replacement'. Example: '“:\"' or '—:' to remove default."
                    },
                    "default": [],
                    "description": "List of suspicious symbols and their replacements. Format: \"symbol:replacement\". Extends defaults. Use empty replacement (e.g. \"—:\") to disable a default symbol."
                },
                "llmSlopChecker.suspiciousWords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "List of suspicious words to highlight. Extends defaults. Prefix with \"-\" to remove a word from defaults. Examples: \"delve\", \"ensure\", \"-tapestry\"."
                },
                "llmSlopChecker.emojiExceptions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "List of emojis to ignore/allow. Extends defaults. Prefix with \"-\" to remove an emoji from defaults. Examples: \"🚀\", \"✨\", \"-⚠️\"."
                },
                "llmSlopChecker.enableProblemsIntegration": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable integration with the Problems view (Diagnostics) to show issues across the workspace."
                }
            }
        },
        "commands": [
            {
                "command": "llmSlopChecker.showIssues",
                "title": "LLM Slop: Show Issues"
            },
            {
                "command": "llmSlopChecker.fixIssues",
                "title": "LLM Slop: Fix Symbols"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "build-vsix": "vsce package",
        "version": "npm version --no-git-tag-version"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.74.0",
        "eslint": "^9.39.2",
        "globals": "^17.3.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.55.0"
    }
}
